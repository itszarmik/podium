# ═══════════════════════════════════════════════════════════════════════════════
# Podium — Production Environment Template
# Copy this to .env and fill in all values before deploying.
# Never commit a filled .env file to git.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Database (PostgreSQL 16) ─────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require
DATABASE_URL=postgresql://podium:CHANGE_ME@db.your-host.com:5432/podium?sslmode=require

# ─── Cache + Real-time (Redis 7) ─────────────────────────────────────────────
# Use Redis Cloud, Upstash, or self-hosted with TLS in production
REDIS_URL=rediss://default:CHANGE_ME@redis.your-host.com:6380

# ─── JWT Auth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
# Must be at least 32 characters. Different values for each secret.
JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_REFRESH_SECRET=GENERATE_DIFFERENT_VALUE_ALSO_BASE64_64
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=production

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slashes)
ALLOWED_ORIGINS=https://podium.gg,https://www.podium.gg

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=200
RATE_LIMIT_WINDOW=60000   # 200 req per 60s per IP

# Score submission throttle per user per board (anti-cheat)
SCORE_SUBMIT_RATE_LIMIT=10   # max 10 score submissions per minute per user per board

# ─── Whop Integration ─────────────────────────────────────────────────────────
# Per-board webhook secrets are stored in boards.integration_config.whop_secret
# Set at the board level, not globally. This is your Whop app credentials:
WHOP_CLIENT_ID=your_whop_client_id
WHOP_CLIENT_SECRET=your_whop_client_secret
WHOP_REDIRECT_URI=https://podium.gg/api/v1/auth/whop/callback

# ─── Spotify Integration (future) ────────────────────────────────────────────
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=https://podium.gg/api/v1/auth/spotify/callback

# ─── AI (Claude) ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
ANTHROPIC_MODEL=claude-opus-4-6

# ─── Email (transactional) ───────────────────────────────────────────────────
# Resend (recommended) or Sendgrid
RESEND_API_KEY=re_CHANGE_ME
EMAIL_FROM=noreply@podium.gg

# ─── Push Notifications ───────────────────────────────────────────────────────
# APNs (iOS) — base64 encode your .p8 file
APNS_KEY_ID=your_key_id
APNS_TEAM_ID=your_team_id
APNS_KEY_BASE64=base64_encoded_p8_file
APNS_BUNDLE_ID=gg.podium.app
APNS_PRODUCTION=true

# FCM (Android)
FCM_SERVER_KEY=your_fcm_server_key

# ─── Monitoring ───────────────────────────────────────────────────────────────
SENTRY_DSN=https://CHANGE_ME@sentry.io/CHANGE_ME
LOG_LEVEL=info

# ─── Web (Next.js public vars) ────────────────────────────────────────────────
# These are baked into the Next.js build — must be set at build time
NEXT_PUBLIC_API_URL=https://api.podium.gg/api/v1
NEXT_PUBLIC_WS_URL=wss://api.podium.gg/api/v1/ws

# ─── Mobile (Expo public vars) ────────────────────────────────────────────────
# Set in apps/mobile/.env (not committed)
EXPO_PUBLIC_API_URL=https://api.podium.gg/api/v1
EXPO_PUBLIC_WS_URL=wss://api.podium.gg/api/v1/ws
