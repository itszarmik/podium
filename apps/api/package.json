{
  "name": "@podium/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "npx esbuild $(find src -name \"*.ts\" | tr \"\n\" \" \") --outdir=dist --platform=node --target=node20 --format=cjs",
    "start": "node dist/server.js",
    "migrate": "tsx src/db/migrate.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@podium/shared": "*",
    "fastify": "^4.26.2",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/websocket": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "pg": "^8.11.3",
    "ioredis": "^5.3.2",
    "bcrypt": "^5.1.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "dotenv": "^16.4.5",
    "pino": "^8.19.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.2",
    "@types/bcrypt": "^5.0.2",
    "@types/uuid": "^9.0.8",
    "@types/node": "^20.11.30",
    "typescript": "^5.3.3",
    "tsx": "^4.7.1",
    "vitest": "^1.5.0"
  },
  "type": "commonjs"
}